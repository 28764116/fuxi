{
  "name": "fuxi",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "lsof -ti :8000 | xargs kill -9 2>/dev/null || true",
    "dev": "npm run predev && concurrently --kill-others -n \"backend,frontend\" -c \"green,cyan\" \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
